OPENAI_API_KEY=sk-your-key-here
# Optional override; defaults to gpt-4o-mini
# INTERVIEWER_MODEL=gpt-4o-mini

# ChromaDB (mount Railway volume at data/chroma for persistence)
# CHROMA_PATH=data/chroma
# CHROMA_COLLECTION=interview_content
# EMBEDDING_MODEL=text-embedding-3-small
# INGEST_ON_STARTUP=true

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000,https://interview-forge-ai-omega.vercel.app

# Regex for additional allowed origins (default allows all *.vercel.app preview/prod URLs)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
